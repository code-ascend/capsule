%define _unpackaged_files_terminate_build 1

Name: capsule
Version: @VERSION@
Release: alt@RELEASE@

Summary: Tool for creating portable Linux containers from OCI images
License: GPL-3.0-or-later
Group: System/Configuration/Packaging
Url: https://altlinux.space/dmitry/capsule
Vcs: https://altlinux.space/dmitry/capsule.git

ExclusiveArch: %go_arches

Source: %name-%version.tar

BuildRequires(pre): rpm-macros-golang
BuildRequires: rpm-build-golang
BuildRequires: golang
BuildRequires: gcc
BuildRequires: glibc-devel-static
BuildRequires: libgpgme-devel

Requires: squashfs-tools
Requires: gcc
Requires: glibc-devel-static
Requires: shadow-submap
Requires: fuse-overlayfs
Requires: containers-common

%description
capsule is a tool for creating portable Linux containers from OCI images,
producing a single self-contained ELF binary.

%prep
%setup

# Fix go vendoring build: rename "[generated]" files
for file in $(find -name "*\[generated\]*"); do
  mv -v "$file" "${file//\[generated\]/}"
done

%build
export GOFLAGS="-mod=vendor"
go build -v \
    -ldflags "-X main.version=%version-%release" \
    -o capsule \
    ./cmd/capsule

%install
install -Dm755 capsule %buildroot%_bindir/capsule

%files
%_bindir/capsule
%doc README.md
%doc LICENSE
