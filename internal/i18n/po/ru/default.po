#: cmd/capsule/main.go:51
msgid "Create portable Linux containers from OCI images"
msgstr "Создание портативных Linux-контейнеров из OCI-образов"

#: cmd/capsule/main.go:52
msgid ""
"capsule is a tool for creating portable Linux containers as single ELF "
"executables.\n"
"It reads a YAML config file specifying the image and commands, then produces "
"a self-contained binary."
msgstr ""
"capsule — инструмент для создания портативных Linux-контейнеров в виде "
"единого ELF-файла.\n"
"Читает YAML-конфиг с описанием образа и команд, на выходе — самодостаточный "
"бинарник."

#: cmd/capsule/main.go:57
msgid "Build a portable container from an OCI image"
msgstr "Собрать портативный контейнер из OCI-образа"

#: cmd/capsule/main.go:59
msgid "Build a portable container from an OCI image using a YAML config file."
msgstr "Собрать портативный контейнер из OCI-образа по YAML-конфигу."

#: cmd/capsule/main.go:65
msgid "Path to YAML config file"
msgstr "Путь к YAML-конфигу"

#: cmd/capsule/main.go:70
msgid "Output file path (overrides config)"
msgstr "Путь к выходному файлу (переопределяет конфиг)"

#: cmd/capsule/main.go:74
msgid "SquashFS compression: zstd, lz4, gzip, xz (overrides config)"
msgstr "Сжатие SquashFS: zstd, lz4, gzip, xz (переопределяет конфиг)"

#: cmd/capsule/main.go:79
msgid "Verbose output"
msgstr "Подробный вывод"

#: cmd/capsule/main.go:88
msgid "Interrupted"
msgstr "Прервано"

#: cmd/capsule/main.go:91
msgid "Error"
msgstr "Ошибка"

#: cmd/capsule/main.go:106
msgid ""
"config file required. Usage: capsule build <config.yaml> or capsule build -c "
"<config.yaml>"
msgstr ""
"требуется конфиг-файл. Использование: capsule build <config.yaml> или "
"capsule build -c <config.yaml>"

#: cmd/capsule/main.go:111
msgid "failed to load config"
msgstr "не удалось загрузить конфиг"

#: cmd/capsule/main.go:163
msgid "Step 1/4: Pulling image and preparing rootfs"
msgstr "Шаг 1/4: загрузка образа и подготовка rootfs"

#: cmd/capsule/main.go:166
msgid "failed to prepare rootfs"
msgstr "не удалось подготовить rootfs"

#: cmd/capsule/main.go:176
msgid "Step 2/4: Running install commands"
msgstr "Шаг 2/4: выполнение install-команд"

#: cmd/capsule/main.go:178
msgid "Running step"
msgstr "Выполнение шага"

#: cmd/capsule/main.go:180
msgid "step %q failed"
msgstr "шаг %q завершился с ошибкой"

#: cmd/capsule/main.go:184
msgid "Step 2/4: Skipping commands (none specified)"
msgstr "Шаг 2/4: пропуск команд (не заданы)"

#: cmd/capsule/main.go:196
msgid "failed to apply rootfs overrides"
msgstr "не удалось применить overrides из rootfs"

#: cmd/capsule/main.go:205
msgid "Step 3/4: Creating SquashFS image"
msgstr "Шаг 3/4: создание SquashFS-образа"

#: cmd/capsule/main.go:208
msgid "failed to create temp dir"
msgstr "не удалось создать временный каталог"

#: cmd/capsule/main.go:215
msgid "failed to create squashfs"
msgstr "не удалось создать squashfs"

#: cmd/capsule/main.go:223
msgid "Step 4/4: Assembling final binary"
msgstr "Шаг 4/4: сборка итогового бинарника"

#: cmd/capsule/main.go:227
msgid "failed to create output directory"
msgstr "не удалось создать выходной каталог"

#: cmd/capsule/main.go:233
msgid "failed to assemble binary"
msgstr "не удалось собрать бинарник"

#: cmd/capsule/main.go:238 cmd/capsule/main.go:240
msgid "Build complete"
msgstr "Сборка завершена"

#: cmd/capsule-runtime/actions.go:170
msgid "capsule symlink %q has no matching exported binary"
msgstr "для симлинка %q не найден экспортированный бинарник"

#: cmd/capsule-runtime/actions.go:210
msgid "Export complete"
msgstr "Экспорт завершён"

#: cmd/capsule-runtime/actions.go:237
msgid "Unexport complete"
msgstr "Экспорт удалён"

#: cmd/capsule-runtime/actions.go:248
msgid "commit refused: other capsule sessions are active; close them first"
msgstr "commit невозможен: активны другие сессии капсулы; сначала закройте их"

#: cmd/capsule-runtime/actions.go:271
msgid "Nothing to commit"
msgstr "Нечего фиксировать"

#: cmd/capsule-runtime/actions.go:278
msgid "Commit complete (%.2f MB)"
msgstr "Изменения зафиксированы (%.2f МБ)"

#: cmd/capsule-runtime/actions.go:293
msgid "update refused: other capsule sessions are active; close them first"
msgstr "update невозможен: активны другие сессии капсулы; сначала закройте их"

#: cmd/capsule-runtime/actions.go:304
msgid "update requires overlay; could not mount unionfs"
msgstr "для update требуется overlay; не удалось смонтировать unionfs"

#: cmd/capsule-runtime/actions.go:345
msgid "Update complete"
msgstr "Обновление завершено"

#: cmd/capsule-runtime/actions.go:354
msgid "Overlay removed:"
msgstr "Overlay удалён:"

#: cmd/capsule-runtime/main.go:65
msgid ""
"capsule: already inside a capsule (host PATH leak); run the in-capsule "
"binary directly instead of the capsule wrapper"
msgstr ""
"capsule: уже внутри капсулы (PATH с хоста просочился); запускайте in-capsule "
"бинарник напрямую, минуя обёртку капсулы"

#: cmd/capsule-runtime/main.go:157
msgid "Portable Linux container runtime"
msgstr "Рантайм портативного Linux-контейнера"

#: cmd/capsule-runtime/main.go:161
msgid "Start an interactive shell inside the capsule"
msgstr "Запустить интерактивный shell внутри капсулы"

#: cmd/capsule-runtime/main.go:170
msgid "Mount the squashfs and print the mount point"
msgstr "Смонтировать squashfs и вывести точку монтирования"

#: cmd/capsule-runtime/main.go:177
msgid "Export apps/binaries to the host (all|apps|binaries)"
msgstr "Экспортировать приложения/бинарники в хост-систему (all|apps|binaries)"

#: cmd/capsule-runtime/main.go:185
msgid "Remove exported apps/binaries (all|apps|binaries)"
msgstr "Удалить экспортированные приложения/бинарники (all|apps|binaries)"

#: cmd/capsule-runtime/main.go:193
msgid "Commit overlay changes into the squashfs image"
msgstr "Зафиксировать изменения overlay в squashfs-образе"

#: cmd/capsule-runtime/main.go:200
msgid "Run the configured update script and commit the result"
msgstr "Выполнить заданный update-скрипт и зафиксировать результат"

#: cmd/capsule-runtime/main.go:207
msgid "Remove overlay data (reset capsule to a clean state)"
msgstr "Удалить данные overlay (сбросить капсулу к исходному состоянию)"

#: cmd/capsule-runtime/main.go:220
msgid "Mount host path into the capsule (`SRC[:DST]`, repeatable)"
msgstr ""
"Смонтировать путь с хоста внутрь капсулы (`SRC[:DST]`, можно повторять)"

#: cmd/capsule-runtime/main.go:226
msgid ""
"Set env var inside the capsule (`KEY=VAL`, repeatable, overrides config)"
msgstr ""
"Задать переменную окружения внутри капсулы (`KEY=VAL`, можно повторять, "
"перекрывает конфиг)"

#: cmd/capsule-runtime/main.go:232
msgid "Drop env var inside the capsule (`KEY`, repeatable)"
msgstr "Удалить переменную окружения внутри капсулы (`KEY`, можно повторять)"

#: cmd/capsule-runtime/main.go:238
msgid "Override capsule home directory (`PATH`)"
msgstr "Переопределить домашний каталог капсулы (`PATH`)"

#: cmd/capsule-runtime/main.go:244
msgid "Enable debug logging"
msgstr "Включить отладочные логи"

#: cmd/capsule-runtime/main.go:249
msgid "Disable unionfs overlay (read-only rootfs)"
msgstr "Отключить unionfs-overlay (rootfs только для чтения)"

#: cmd/capsule-runtime/main.go:254
msgid "Skip NVIDIA driver passthrough"
msgstr "Пропустить проброс драйверов NVIDIA"

#: cmd/capsule-runtime/main.go:259
msgid "Squashfs FUSE backend: `auto|3|ll` (3 is lighter; ll is faster)"
msgstr "FUSE-бэкенд для squashfs: `auto|3|ll` (3 экономнее, ll быстрее)"

