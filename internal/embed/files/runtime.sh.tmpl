#!/bin/bash
# capsule runtime script
# This script is executed by the init launcher via memfd

set -e

unset LD_PRELOAD LD_LIBRARY_PATH

# Component sizes (filled at build time)
INIT_SIZE={{.InitSize}}
BASH_SIZE={{.BashSize}}
SCRIPT_SIZE={{.ScriptSize}}
UTILS_SIZE={{.UtilsSize}}

# Default launch command (empty means /bin/bash)
LAUNCH_CMD="{{.Launch}}"

# Export configuration (apps: desktop|icon|suffix per line)
EXPORT_APPS='{{.ExportAppsLines}}'
EXPORT_BINARIES={{.ExportBinariesBash}}

# Compression type for mksquashfs (used by --commit/--update)
COMPRESSION="{{.Compression}}"

# Update script (used by --update)
UPDATE_SCRIPT='{{.UpdateScript}}'

# Environment variable overrides from YAML config
ENV_UNSET={{.EnvUnsetBash}}
ENV_SET={{.EnvSetBash}}

# Calculate offsets
UTILS_OFFSET=$((INIT_SIZE + BASH_SIZE + SCRIPT_SIZE))
IMAGE_OFFSET=$((INIT_SIZE + BASH_SIZE + SCRIPT_SIZE + UTILS_SIZE))

# Get path to the container binary
SCRIPT="${CAPSULE_SELF:-$(readlink -f "$0")}"

# Executable and capsule names for symlink detection
EXEC_NAME=$(basename "$0")
CAPSULE_NAME=$(basename "$SCRIPT")

# Working directory
WORKING_DIR="${XDG_RUNTIME_DIR:-/tmp}/capsule_$$"

# Overlay directory (persistent across runs)
OVERLAY_BASE=""
OVERLAY_MERGED=""

# XDG directories for export
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_BIN_HOME="${HOME}/.local/bin"

# Cleanup function
cleanup() {
    if [ -n "$OVERLAY_MERGED" ] && mountpoint -q "$OVERLAY_MERGED" 2>/dev/null; then
        fusermount -u "$OVERLAY_MERGED" 2>/dev/null || \
            fusermount -uz "$OVERLAY_MERGED" 2>/dev/null || true
    fi

    if [ -n "$WORKING_DIR" ] && [ -d "$WORKING_DIR" ]; then
        if mountpoint -q "$WORKING_DIR/mnt" 2>/dev/null; then
            fusermount -u "$WORKING_DIR/mnt" 2>/dev/null || \
                fusermount -uz "$WORKING_DIR/mnt" 2>/dev/null || true
        fi
        rm -rf "$WORKING_DIR" 2>/dev/null || true
    fi
}
trap cleanup EXIT

# Prepare merged /etc/passwd, /etc/group, /etc/shadow
prepare_merged_user_files() {
    local root_path="$1"

    [ -n "$CAPSULE_DEBUG" ] && echo "=== prepare_merged_user_files: root_path=$root_path ===" >&2

    if [ ! -f "$root_path/etc/passwd" ]; then
        [ -n "$CAPSULE_DEBUG" ] && echo "=== ERROR: $root_path/etc/passwd not found! ===" >&2
        return 0
    fi

    local merged_dir="$WORKING_DIR/etc"
    mkdir -p "$merged_dir"
    [ -n "$CAPSULE_DEBUG" ] && echo "=== Creating merged files in $merged_dir ===" >&2

    local host_user="${USER:-$(id -un)}"
    local host_uid=$(id -u)
    local host_gid=$(id -g)
    local host_home="${HOME:-/home/$host_user}"
    local host_shell="${SHELL:-/bin/bash}"
    local host_gecos="${host_user}"

    # Merge /etc/passwd
    {
        awk -F: -v uid="$host_uid" '$3 != uid' "$root_path/etc/passwd"
        echo "$host_user:x:$host_uid:$host_gid:$host_gecos:$host_home:$host_shell"
    } > "$merged_dir/passwd"

    # Merge /etc/group
    if [ -f "$root_path/etc/group" ]; then
        awk -F: -v gid="$host_gid" '$3 != gid' "$root_path/etc/group" > "$merged_dir/group"

        local host_group=$(id -gn)
        echo "$host_group:x:$host_gid:$host_user" >> "$merged_dir/group"

        if grep -q '^wheel:' "$root_path/etc/group"; then
            if grep -q '^wheel:' "$merged_dir/group"; then
                if grep -q '^wheel:x:[0-9]*:$' "$merged_dir/group"; then
                    sed -i "s/^\(wheel:x:[0-9]*:\)$/\1${host_user}/" "$merged_dir/group"
                else
                    sed -i "s/^\(wheel:x:[0-9]*:\)\(.*\)/\1\2,${host_user}/" "$merged_dir/group"
                fi
            else
                local wheel_gid=$(grep '^wheel:' "$root_path/etc/group" | cut -d: -f3)
                if [ "$wheel_gid" != "$host_gid" ]; then
                    echo "wheel:x:$wheel_gid:$host_user" >> "$merged_dir/group"
                fi
            fi
        fi
        if grep -q '^sudo:' "$root_path/etc/group"; then
            if grep -q '^sudo:' "$merged_dir/group"; then
                if grep -q '^sudo:x:[0-9]*:$' "$merged_dir/group"; then
                    sed -i "s/^\(sudo:x:[0-9]*:\)$/\1${host_user}/" "$merged_dir/group"
                else
                    sed -i "s/^\(sudo:x:[0-9]*:\)\(.*\)/\1\2,${host_user}/" "$merged_dir/group"
                fi
            else
                local sudo_gid=$(grep '^sudo:' "$root_path/etc/group" | cut -d: -f3)
                if [ "$sudo_gid" != "$host_gid" ]; then
                    echo "sudo:x:$sudo_gid:$host_user" >> "$merged_dir/group"
                fi
            fi
        fi
    fi

    # Merge /etc/shadow:
    if [ -f "$root_path/etc/shadow" ]; then
        {
            grep -v "^${host_user}:" "$root_path/etc/shadow" 2>/dev/null || true
            echo "$host_user::19000:0:99999:7:::"
        } > "$merged_dir/shadow"
        chmod 600 "$merged_dir/shadow"
    fi

    [ -n "$CAPSULE_DEBUG" ] && echo "=== Merged user files created in $merged_dir ===" >&2
    return 0
}

# Initialize overlay with merged user files
init_overlay_user_files() {
    local passwd_file="$OVERLAY_BASE/upper/etc/passwd"
    local group_file="$OVERLAY_BASE/upper/etc/group"
    local shadow_file="$OVERLAY_BASE/upper/etc/shadow"
    local host_user="${USER:-$(id -un)}"
    local host_uid=$(id -u)
    local host_gid=$(id -g)
    local host_gecos=$(getent passwd "$host_user" | cut -d: -f5)
    local host_home="${HOME}"
    local host_shell="${SHELL:-/bin/bash}"

    # Check if update is needed
    if [ -f "$passwd_file" ]; then
        if grep -q "^${host_user}:.*:${host_uid}:" "$passwd_file"; then
            [ -n "$CAPSULE_DEBUG" ] && echo "=== Host user ${host_user}:${host_uid} already in overlay ===" >&2
            return 0
        fi
        [ -n "$CAPSULE_DEBUG" ] && echo "=== Host user changed, updating overlay user files ===" >&2

        sed -i "/^${host_user}:/d" "$passwd_file"
        sed -i "/^${host_user}:/d" "$group_file" 2>/dev/null || true
        sed -i "/^${host_user}:/d" "$shadow_file" 2>/dev/null || true

        echo "${host_user}:x:${host_uid}:${host_gid}:${host_gecos}:${host_home}:${host_shell}" >> "$passwd_file"
        echo "${host_user}:x:${host_gid}:" >> "$group_file"
        echo "${host_user}:!!:::::::" >> "$shadow_file"

        # Add user to wheel/sudo groups if they exist
        if grep -q "^wheel:" "$group_file"; then
            sed -i "s/^\(wheel:x:[0-9]*:\)\(.*\)$/\1\2,${host_user}/" "$group_file"
            sed -i "s/,:/:/" "$group_file"
        fi
        if grep -q "^sudo:" "$group_file"; then
            sed -i "s/^\(sudo:x:[0-9]*:\)\(.*\)$/\1\2,${host_user}/" "$group_file"
            sed -i "s/,:/:/" "$group_file"
        fi

        [ -n "$CAPSULE_DEBUG" ] && echo "=== Updated host user in overlay ===" >&2
    else
        [ -n "$CAPSULE_DEBUG" ] && echo "=== First run, initializing overlay user files ===" >&2

        prepare_merged_user_files "$WORKING_DIR/mnt"

        mkdir -p "$OVERLAY_BASE/upper/etc"
        for f in passwd group shadow; do
            if [ -e "$WORKING_DIR/etc/$f" ]; then
                cp -f "$WORKING_DIR/etc/$f" "$OVERLAY_BASE/upper/etc/$f"
                [ -n "$CAPSULE_DEBUG" ] && echo "=== Copied merged $f to overlay/upper/etc ===" >&2
            fi
        done
    fi

    [ -n "$CAPSULE_DEBUG" ] && echo "=== Overlay user files ready ===" >&2
    return 0
}

# Print help
show_help() {
    cat << HELP
capsule - Portable Linux Container

Usage:
    $CAPSULE_NAME [OPTIONS] [COMMAND] [ARGS...]

Options:
    --help              Show this help message
    --shell             Start an interactive shell
    --mount-only        Only mount the container, print mount point
    --export [FILTER]   Export apps/binaries to host (all|apps|binaries)
    --unexport [FILTER] Remove exported apps/binaries (all|apps|binaries)
    --commit            Commit overlay changes into the squashfs image
    --update            Run update script inside container and commit
    --clean             Remove overlay data (reset container to clean state)

Environment Variables:
    CAPSULE_HOME        Directory to bind as home (default: \$HOME)
    CAPSULE_BIND        Additional bind mounts (format: src:dst,src:dst)
    CAPSULE_DEBUG       Enable debug output
    CAPSULE_OVERLAYFS   Writable overlay over squashfs (default: 1, set 0 to disable)
    CAPSULE_OVERLAY_DIR Directory for overlay data (default: ~/.local/share/capsule/overlay_HASH)
    CAPSULE_NO_NVIDIA   Disable automatic NVIDIA driver library link inside

Examples:
    $CAPSULE_NAME --shell              Start a shell
    $CAPSULE_NAME /bin/ls /            List root directory
    $CAPSULE_NAME --export             Export desktop files and symlinks
    $CAPSULE_NAME --unexport           Remove exported files
HELP
}

# Extract utils (bwrap, squashfuse, libs)
extract_utils() {
    if [ -d "$WORKING_DIR/utils" ]; then
        return 0
    fi

    mkdir -p "$WORKING_DIR"

    # Extract utils.tar.gz from the binary (archive contains utils/ directory)
    # Use larger block size for speed, with tail for offset
    tail -c +$((UTILS_OFFSET + 1)) "$SCRIPT" | head -c "$UTILS_SIZE" | \
        tar -xzf - -C "$WORKING_DIR"

    # Make binaries executable
    chmod +x "$WORKING_DIR/utils/"* 2>/dev/null || true
}

# Run bundled utility via ld-linux
run_util() {
    "$WORKING_DIR/utils/ld-linux-x86-64.so.2" \
        --library-path "$WORKING_DIR/utils" \
        "$@"
}

# Mount SquashFS image
mount_image() {
    if mountpoint -q "$WORKING_DIR/mnt" 2>/dev/null; then
        return 0
    fi

    mkdir -p "$WORKING_DIR/mnt"

    # Prefer squashfuse_ll (low-level, faster) if available
    local squashfuse_bin="$WORKING_DIR/utils/squashfuse"
    if [ -x "$WORKING_DIR/utils/squashfuse_ll" ]; then
        squashfuse_bin="$WORKING_DIR/utils/squashfuse_ll"
    fi

    # Mount using squashfuse with offset
    run_util "$squashfuse_bin" -o offset="$IMAGE_OFFSET" "$SCRIPT" "$WORKING_DIR/mnt"
}

# Mount overlay filesystem (unionfs-fuse over squashfs)
mount_overlay() {
    local script_hash
    script_hash=$(echo "$SCRIPT" | md5sum | cut -c1-8)
    OVERLAY_BASE="${CAPSULE_OVERLAY_DIR:-$HOME/.local/share/capsule/overlay_$script_hash}"
    OVERLAY_MERGED="$OVERLAY_BASE/merged"

    mkdir -p "$OVERLAY_BASE/upper" "$OVERLAY_BASE/work" "$OVERLAY_MERGED"

    # Initialize user files in overlay (first run or user changed)
    init_overlay_user_files

    if mountpoint -q "$OVERLAY_MERGED" 2>/dev/null; then
        fusermount -u "$OVERLAY_MERGED" 2>/dev/null || true
    fi

    local unionfs_bin="$WORKING_DIR/utils/unionfs"
    if [ -x "$WORKING_DIR/utils/unionfs3" ]; then
        unionfs_bin="$WORKING_DIR/utils/unionfs3"
    fi

    if [ ! -x "$unionfs_bin" ]; then
        echo "Warning: unionfs not found, overlay disabled" >&2
        OVERLAY_MERGED=""
        return 1
    fi

    local unionfs_opts="cow,noatime"
    [ "$(id -u)" != "0" ] && unionfs_opts="$unionfs_opts,relaxed_permissions"

    if ! run_util "$unionfs_bin" \
        -o "$unionfs_opts" \
        "$OVERLAY_BASE/upper=RW:$WORKING_DIR/mnt=RO" \
        "$OVERLAY_MERGED"; then
        echo "Warning: unionfs mount failed, overlay disabled" >&2
        OVERLAY_MERGED=""
        return 1
    fi

    if [ -n "$CAPSULE_DEBUG" ]; then
        echo "Overlay mounted at $OVERLAY_MERGED" >&2
        echo "  Upper (RW): $OVERLAY_BASE/upper" >&2
        echo "  Lower (RO): $WORKING_DIR/mnt" >&2
    fi
}

{{ template "nvidia.sh" . }}

# Execute command inside container via bwrap (returns exit code, does not exit)
bwrap_exec() {
    local cmd=("$@")

    # Default to launch command or shell if no command
    if [ ${#cmd[@]} -eq 0 ]; then
        if [ -n "$LAUNCH_CMD" ]; then
            cmd=($LAUNCH_CMD)
        else
            cmd=("/bin/bash")
        fi
    fi

    # Home directory
    local home_dir="${CAPSULE_HOME:-$HOME}"

    # Determine root path: overlay or squashfs
    local root_path="$WORKING_DIR/mnt"
    local root_bind="--ro-bind"
    if [ -n "$OVERLAY_MERGED" ] && mountpoint -q "$OVERLAY_MERGED" 2>/dev/null; then
        root_path="$OVERLAY_MERGED"
        root_bind="--bind"  # overlay is writable
    fi

    # Prepare merged user files (passwd/group/shadow) - only for non-overlay mode
    if [ -z "$OVERLAY_MERGED" ]; then
        prepare_merged_user_files "$root_path"
    fi

    # Build bwrap command
    local bwrap_args=(
        $root_bind "$root_path" /
        --dev-bind /dev /dev
        --ro-bind /sys /sys
        --proc /proc
        --bind-try /tmp /tmp
        --bind-try /run /run
        --bind-try /run/dbus /run/dbus
        --bind-try /var/tmp /var/tmp
        --bind-try /mnt /mnt
        --bind-try /media /media
    )

    # Bind host /etc files on top of container's /etc
    # Only bind if target exists in container (ro-bind needs existing target)
    local etc_files="resolv.conf hosts nsswitch.conf localtime machine-id asound.conf"
    for f in $etc_files; do
        if [ -e "$root_path/etc/$f" ] && [ -e "/etc/$f" ]; then
            bwrap_args+=(--ro-bind "/etc/$f" "/etc/$f")
        fi
    done

    # Bind merged user files (passwd/group/shadow) - only for non-overlay mode
    if [ -z "$OVERLAY_MERGED" ]; then
        for f in passwd group shadow; do
            if [ -e "$WORKING_DIR/etc/$f" ] && [ -e "$root_path/etc/$f" ]; then
                bwrap_args+=(--ro-bind "$WORKING_DIR/etc/$f" "/etc/$f")
            fi
        done
    fi

    # Handle home directory - use tmpfs overlay for non-standard paths
    if [ -d "$home_dir" ]; then
        local home_tmp="${home_dir#/}"
        local home_top="/${home_tmp%%/*}"

        case "$home_top" in
            /home)
                bwrap_args+=(--bind-try /home /home)
                ;;
            *)
                # Non-standard home (like /var/home) - remap to /home/$USER
                local container_home="/home/${USER:-user}"
                bwrap_args+=(--tmpfs /home)
                bwrap_args+=(--dir "$container_home")
                bwrap_args+=(--bind "$home_dir" "$container_home")
                bwrap_args+=(--setenv HOME "$container_home")
                bwrap_args+=(--setenv XDG_CONFIG_HOME "$container_home/.config")
                bwrap_args+=(--setenv XDG_DATA_HOME "$container_home/.local/share")
                ;;
        esac
    fi

    # Parse additional bind mounts from CAPSULE_BIND
    if [ -n "$CAPSULE_BIND" ]; then
        IFS=',' read -ra binds <<< "$CAPSULE_BIND"
        for bind in "${binds[@]}"; do
            IFS=':' read -ra parts <<< "$bind"
            if [ ${#parts[@]} -eq 2 ]; then
                bwrap_args+=(--bind "${parts[0]}" "${parts[1]}")
            elif [ ${#parts[@]} -eq 1 ]; then
                bwrap_args+=(--bind "${parts[0]}" "${parts[0]}")
            fi
        done
    fi

    # Set environment
    bwrap_args+=(
        --setenv PATH "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
        --setenv TERM "${TERM:-xterm}"
        --setenv LANG "${LANG:-C.UTF-8}"
        --setenv XDG_DATA_DIRS "/usr/local/share:/usr/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"
    )

    # User-configured env overrides from YAML
    for v in "${ENV_UNSET[@]}"; do
        bwrap_args+=(--unsetenv "$v")
    done
    for entry in "${ENV_SET[@]}"; do
        local key="${entry%%=*}" val="${entry#*=}"
        bwrap_args+=(--setenv "$key" "$val")
    done

    if [ -n "$CAPSULE_DEBUG" ]; then
        echo "=== Capsule environment ===" >&2
        env | sort >&2
        echo "=== bwrap command ===" >&2
        echo "Running: $WORKING_DIR/utils/bwrap ${bwrap_args[*]} ${cmd[*]}" >&2
    fi

    # Execute as subprocess (not exec) to allow cleanup trap to run
    local exit_code=0
    run_util "$WORKING_DIR/utils/bwrap" "${bwrap_args[@]}" "${cmd[@]}" || exit_code=$?
    return $exit_code
}

# Run command in container (calls bwrap_exec and exits)
run_container() {
    bwrap_exec "$@"
    exit $?
}

# Check if invoked via symlink
is_symlink_invocation() {
    [ "$EXEC_NAME" != "$CAPSULE_NAME" ]
}

# Get command for symlink invocation
get_symlink_command() {
    local name="$1"
    for bin in "${EXPORT_BINARIES[@]}"; do
        [ "$bin" = "$name" ] && echo "$bin" && return 0
    done
    return 1
}

# Export apps and/or binaries
do_export() {
    local filter="${1:-all}"
    extract_utils
    mount_image

    case "$filter" in
        all)      export_apps; export_binaries ;;
        apps)     export_apps ;;
        binaries) export_binaries ;;
        *)        echo "Unknown export filter: $filter" >&2; exit 1 ;;
    esac

    # Update caches for GNOME/GTK environments
    if [[ "$XDG_CURRENT_DESKTOP" == *"GNOME"* ]]; then
        gtk-update-icon-cache -f -t ~/.local/share/icons/hicolor/ 2>/dev/null || true
        update-desktop-database ~/.local/share/applications/ 2>/dev/null || true
    fi

    echo "Export complete"
}

# Unexport apps and/or binaries
do_unexport() {
    local filter="${1:-all}"
    case "$filter" in
        all)      unexport_apps; unexport_binaries ;;
        apps)     unexport_apps ;;
        binaries) unexport_binaries ;;
        *)        echo "Unknown unexport filter: $filter" >&2; exit 1 ;;
    esac
    echo "Unexport complete"
}

# Export .desktop files
export_apps() {
    [ -z "$EXPORT_APPS" ] && return 0
    mkdir -p "$XDG_DATA_HOME/applications"

    local root="$WORKING_DIR/mnt"
    # Parse line format: desktop|icon|suffix
    echo "$EXPORT_APPS" | while IFS='|' read -r desktop icon suffix; do
        [ -z "$desktop" ] && continue
        export_single_app "$root" "$desktop" "$icon" "$suffix"
    done
}

# Export a single .desktop file
export_single_app() {
    local root="$1" desktop_path="$2" icon_name="$3" name_suffix="$4"
    local src="$root$desktop_path"
    [ ! -f "$src" ] && { echo "Warning: $desktop_path not found" >&2; return 1; }

    local dest_name="$(basename "$desktop_path")"
    local dest="$XDG_DATA_HOME/applications/$dest_name"

    transform_desktop "$src" "$dest" "$name_suffix" "$icon_name"
    echo "Desktop: $dest"
    if [ -n "$icon_name" ]; then
        export_icon "$root" "$icon_name"
    fi
}

# Transform .desktop file for capsule
transform_desktop() {
    local src="$1" dest="$2" suffix="$3" icon_name="$4"
    local capsule_path=$(readlink -f "$SCRIPT")

    while IFS= read -r line; do
        case "$line" in
            Exec=*)
                local cmd="${line#Exec=}"
                local first_word="${cmd%% *}"
                first_word="${first_word//\"/}"
                local rest="${cmd#* }"
                [ "$rest" = "$cmd" ] && rest=""
                echo "Exec=$capsule_path $first_word $rest"
                ;;
            TryExec=*)
                # Skip TryExec - capsule handles this
                ;;
            Icon=*)
                if [ -n "$icon_name" ]; then
                    echo "Icon=${icon_name}"
                else
                    echo "$line"
                fi
                ;;
            Name=*|Name\[*)
                [ -n "$suffix" ] && echo "${line}${suffix}" || echo "$line"
                ;;
            *)
                echo "$line"
                ;;
        esac
    done < "$src" > "$dest"
}

# Export icon from container
export_icon() {
    local root="$1" icon_name="$2"
    local sizes=("256x256" "128x128" "64x64" "48x48" "scalable")

    for size in "${sizes[@]}"; do
        local ext="png"
        [ "$size" = "scalable" ] && ext="svg"
        local src="$root/usr/share/icons/hicolor/$size/apps/$icon_name.$ext"
        if [ -f "$src" ]; then
            local dest_dir="$XDG_DATA_HOME/icons/hicolor/$size/apps"
            local dest="$dest_dir/${icon_name}.$ext"
            mkdir -p "$dest_dir"
            cp "$src" "$dest"
            echo "Icon:    $dest"
            return 0
        fi
    done

    for ext in png svg xpm; do
        local src="$root/usr/share/pixmaps/$icon_name.$ext"
        if [ -f "$src" ]; then
            local dest="$XDG_DATA_HOME/icons/hicolor/48x48/apps/${icon_name}.$ext"
            mkdir -p "$XDG_DATA_HOME/icons/hicolor/48x48/apps"
            cp "$src" "$dest"
            echo "Icon:    $dest"
            return 0
        fi
    done
}

# Export binary wrappers
export_binaries() {
    [ ${#EXPORT_BINARIES[@]} -eq 0 ] && return 0
    mkdir -p "$XDG_BIN_HOME"

    local capsule_path=$(readlink -f "$SCRIPT")
    for bin in "${EXPORT_BINARIES[@]}"; do
        local name=$(basename "$bin")
        local wrapper="$XDG_BIN_HOME/$name"
        [ -e "$wrapper" ] && { echo "Skip:    $wrapper (exists)"; continue; }
        cat > "$wrapper" << EOF
#!/bin/sh
exec "$capsule_path" "$bin" "\$@"
EOF
        chmod +x "$wrapper"
        echo "Binary:  $wrapper"
    done
}

# Remove exported binaries
unexport_binaries() {
    local capsule_path=$(readlink -f "$SCRIPT")
    for bin in "${EXPORT_BINARIES[@]}"; do
        local name=$(basename "$bin")
        local wrapper="$XDG_BIN_HOME/$name"
        if [ -f "$wrapper" ] && grep -q "$capsule_path" "$wrapper" 2>/dev/null; then
            rm "$wrapper"
            echo "Removed: $wrapper"
        fi
    done
}

# Remove exported apps and icons
unexport_apps() {
    [ -z "$EXPORT_APPS" ] && return 0
    echo "$EXPORT_APPS" | while IFS='|' read -r desktop icon suffix; do
        if [ -n "$desktop" ]; then
            local file="$XDG_DATA_HOME/applications/$(basename "$desktop")"
            [ -f "$file" ] && rm -f "$file" && echo "Removed: $file"
        fi
        if [ -n "$icon" ]; then
            find "$XDG_DATA_HOME/icons/hicolor" -name "${icon}.*" -print -delete 2>/dev/null | while read -r f; do
                echo "Removed: $f"
            done
        fi
    done
}

# Commit overlay changes into the squashfs image inside the binary
do_commit() {
    local script_hash
    script_hash=$(echo "$SCRIPT" | md5sum | cut -c1-8)
    local overlay_dir="${CAPSULE_OVERLAY_DIR:-$HOME/.local/share/capsule/overlay_$script_hash}"
    local upper_dir="$overlay_dir/upper"

    if [ ! -d "$upper_dir" ] || [ -z "$(ls -A "$upper_dir" 2>/dev/null)" ]; then
        echo "Nothing to commit"
        exit 0
    fi

    echo "Committing overlay changes..."

    # Remove NVIDIA host-specific files before baking into portable image
    nvidia_clean_upper "$upper_dir"

    extract_utils
    mount_image

    OVERLAY_BASE="$overlay_dir"
    OVERLAY_MERGED="$overlay_dir/merged"
    mkdir -p "$OVERLAY_MERGED"

    local unionfs_bin="$WORKING_DIR/utils/unionfs"
    if [ -x "$WORKING_DIR/utils/unionfs3" ]; then
        unionfs_bin="$WORKING_DIR/utils/unionfs3"
    fi

    if [ ! -x "$unionfs_bin" ]; then
        echo "Error: unionfs not found, cannot merge overlay" >&2
        exit 1
    fi

    local unionfs_opts="cow,noatime"
    [ "$(id -u)" != "0" ] && unionfs_opts="$unionfs_opts,relaxed_permissions"

    run_util "$unionfs_bin" \
        -o "$unionfs_opts" \
        "$upper_dir=RW:$WORKING_DIR/mnt=RO" \
        "$OVERLAY_MERGED"

    local comp_args=()
    case "$COMPRESSION" in
        zstd) comp_args=(-b 1M -Xcompression-level 19) ;;
        xz)   comp_args=(-b 1M -Xbcj x86) ;;
        lz4)  comp_args=(-b 256K -Xhc) ;;
        gzip) comp_args=(-b 1M) ;;
    esac

    # Write temp files next to the binary (same FS for atomic mv)
    local script_dir
    script_dir=$(dirname "$SCRIPT")
    local new_squashfs="$script_dir/.capsule_new.squashfs"
    local new_binary="$script_dir/.capsule_new"

    echo "Building new squashfs image (compression: $COMPRESSION)..."
    run_util "$WORKING_DIR/utils/mksquashfs" \
        "$OVERLAY_MERGED" "$new_squashfs" \
        -comp "$COMPRESSION" \
        -noappend -no-xattrs \
        "${comp_args[@]}" \
        -quiet

    # Unmount overlay before replacing binary
    fusermount -u "$OVERLAY_MERGED" 2>/dev/null || true
    fusermount -u "$WORKING_DIR/mnt" 2>/dev/null || true
    OVERLAY_MERGED=""

    # Reassemble: header (init+bash+script+utils) + new squashfs
    head -c "$IMAGE_OFFSET" "$SCRIPT" > "$new_binary"
    cat "$new_squashfs" >> "$new_binary"
    rm -f "$new_squashfs"

    # Atomic replace (same FS → rename syscall)
    chmod +x "$new_binary"
    mv -f "$new_binary" "$SCRIPT"

    rm -rf "$upper_dir"
    mkdir -p "$upper_dir"

    local size_mb
    size_mb=$(stat -c%s "$SCRIPT" 2>/dev/null || stat -f%z "$SCRIPT" 2>/dev/null)
    size_mb=$(echo "scale=2; $size_mb / 1048576" | bc 2>/dev/null || echo "?")
    echo "Commit complete (${size_mb} MB)"

    # If running under sudo, clean user's overlay too
    if [ "$(id -u)" = "0" ] && [ -n "$SUDO_USER" ]; then
        local script_hash
        script_hash=$(echo "$SCRIPT" | md5sum | cut -c1-8)
        local user_home
        user_home=$(getent passwd "$SUDO_USER" | cut -d: -f6)
        if [ -n "$user_home" ] && [ -d "$user_home" ]; then
            local user_overlay="$user_home/.local/share/capsule/overlay_$script_hash"
            clean_overlay_dir "$user_overlay" && echo "Cleaned user overlay: $user_overlay"
        fi
    fi
}

# Clean overlay directory (unmount and remove)
clean_overlay_dir() {
    local overlay_dir="$1"
    local quiet="${2:-false}"

    if [ ! -d "$overlay_dir" ]; then
        [ "$quiet" != "true" ] && echo "Nothing to clean"
        return 1
    fi

    if mountpoint -q "$overlay_dir/merged" 2>/dev/null; then
        fusermount -u "$overlay_dir/merged" 2>/dev/null || true
    fi

    rm -rf "$overlay_dir"
    [ "$quiet" != "true" ] && echo "Overlay removed: $overlay_dir"
    return 0
}

# Remove overlay data (reset to clean squashfs state)
do_clean() {
    local script_hash
    script_hash=$(echo "$SCRIPT" | md5sum | cut -c1-8)
    local overlay_dir="${CAPSULE_OVERLAY_DIR:-$HOME/.local/share/capsule/overlay_$script_hash}"

    clean_overlay_dir "$overlay_dir" || exit 0
}

# Run update script inside container, then commit changes
do_update() {
    if [ -z "$UPDATE_SCRIPT" ]; then
        echo "Error: no update script defined in capsule config" >&2
        exit 1
    fi

    if [ "$(id -u)" != "0" ]; then
        echo "Error: --update requires root privileges. Run with: sudo $SCRIPT --update" >&2
        exit 1
    fi

    echo "Running update script..."

    extract_utils
    mount_image

    mount_overlay || { echo "Error: failed to mount overlay for update" >&2; exit 1; }

    # Backup upper dir to rollback on failure
    local upper_backup="$OVERLAY_BASE/upper_backup"
    rm -rf "$upper_backup"
    cp -a "$OVERLAY_BASE/upper" "$upper_backup"

    local exit_code=0
    bwrap_exec /bin/bash -c "set -e; $UPDATE_SCRIPT" || exit_code=$?

    if [ $exit_code -ne 0 ]; then
        echo "Error: update script failed with exit code $exit_code, rolling back..." >&2
        if [ -n "$OVERLAY_MERGED" ] && mountpoint -q "$OVERLAY_MERGED" 2>/dev/null; then
            fusermount -u "$OVERLAY_MERGED" 2>/dev/null || true
            OVERLAY_MERGED=""
        fi
        rm -rf "$OVERLAY_BASE/upper"
        mv "$upper_backup" "$OVERLAY_BASE/upper"
        exit $exit_code
    fi

    rm -rf "$upper_backup"

    # Unmount overlay before commit (squashfuse stays — do_commit reuses it)
    if [ -n "$OVERLAY_MERGED" ] && mountpoint -q "$OVERLAY_MERGED" 2>/dev/null; then
        fusermount -u "$OVERLAY_MERGED" 2>/dev/null || true
        OVERLAY_MERGED=""
    fi

    # Commit the changes
    do_commit
}

# Main
main() {
    if is_symlink_invocation; then
        local cmd
        if cmd=$(get_symlink_command "$EXEC_NAME"); then
            extract_utils
            mount_image
            if [ "${CAPSULE_OVERLAYFS:-1}" != "0" ] && mount_overlay; then
                nvidia_check && nvidia_setup
            fi
            run_container "$cmd" "$@"
            exit $?
        fi
    fi

    # Parse arguments
    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --shell|-s)
            shift
            set -- /bin/bash "$@"
            ;;
        --mount-only)
            extract_utils
            mount_image
            echo "$WORKING_DIR/mnt"
            trap - EXIT
            exit 0
            ;;
        --export)
            shift
            do_export "${1:-all}"
            exit 0
            ;;
        --unexport)
            shift
            do_unexport "${1:-all}"
            exit 0
            ;;
        --commit)
            do_commit
            exit 0
            ;;
        --update)
            do_update
            exit 0
            ;;
        --clean)
            do_clean
            exit 0
            ;;
    esac

    extract_utils
    mount_image

    if [ "${CAPSULE_OVERLAYFS:-1}" != "0" ] && mount_overlay; then
        nvidia_check && nvidia_setup
    fi

    run_container "$@"
}

main "$@"
