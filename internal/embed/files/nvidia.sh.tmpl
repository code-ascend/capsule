{{- define "nvidia.sh" -}}
nvidia_check() {
    [ -n "${CAPSULE_NO_NVIDIA:-}" ] && return 1
    [ -f /sys/module/nvidia/version ]
}

nvidia_get_version() {
    cat /sys/module/nvidia/version
}

nvidia_is_cached() {
    local marker="$OVERLAY_BASE/nvidia_version"
    [ -f "$marker" ] && [ "$(cat "$marker")" = "$(nvidia_get_version)" ]
}

# Detect container's lib directory layout (Debian multiarch / Fedora-Arch / flat)
nvidia_detect_libdir() {
    local root="$OVERLAY_MERGED"
    if [ -d "$root/usr/lib/x86_64-linux-gnu" ]; then
        NVIDIA_LIB64="usr/lib/x86_64-linux-gnu"
        NVIDIA_LIB32="usr/lib/i386-linux-gnu"
    elif [ -d "$root/usr/lib64" ] && [ ! -L "$root/usr/lib64" ]; then
        NVIDIA_LIB64="usr/lib64"
        NVIDIA_LIB32="usr/lib"
    else
        NVIDIA_LIB64="usr/lib"
        NVIDIA_LIB32="usr/lib32"
    fi
}

# Remove NVIDIA host-specific files from overlay (before --commit)
nvidia_clean_upper() {
    local upper="${1:-$OVERLAY_BASE/upper}"
    [ ! -d "$upper" ] && return 0

    local dir
    for dir in usr/lib usr/lib32 usr/lib64 usr/lib/x86_64-linux-gnu usr/lib/i386-linux-gnu; do
        [ ! -d "$upper/$dir" ] && continue
        rm -f "$upper/$dir"/libnvidia* "$upper/$dir"/libcuda* \
              "$upper/$dir"/libnvcuvid* "$upper/$dir"/libnvoptix* \
              "$upper/$dir"/libvdpau_nvidia* "$upper/$dir"/libGLX_nvidia* \
              "$upper/$dir"/libEGL_nvidia* "$upper/$dir"/libGLES*_nvidia* \
              "$upper/$dir"/libnvrtc* "$upper/$dir"/libnv*.so* \
              "$upper/$dir"/libwayland-server.so* \
              2>/dev/null || true
    done

    rm -f "$upper/usr/bin/nvidia-smi" "$upper/usr/bin/nvidia-debugdump" \
          "$upper/usr/bin/nvidia-persistenced" "$upper/usr/bin/nvidia-cuda-mps-control" \
          "$upper/usr/bin/nvidia-cuda-mps-server" 2>/dev/null || true

    rm -f "$upper/usr/share/vulkan/icd.d/nvidia_"*.json 2>/dev/null || true
    rm -f "$upper/usr/share/vulkan/implicit_layer.d/nvidia_"*.json 2>/dev/null || true
    rm -f "$upper/usr/share/glvnd/egl_vendor.d/"*nvidia* 2>/dev/null || true
    rm -f "$upper/usr/share/egl/egl_external_platform.d/"*nvidia* 2>/dev/null || true
    rm -rf "$upper/usr/lib/nvidia/wine" 2>/dev/null || true
    rm -f "$upper/usr/share/nvidia/nvidia-application-profiles-"*-rc 2>/dev/null || true

    for dir in usr/lib/dri usr/lib32/dri usr/lib64/dri usr/lib/x86_64-linux-gnu/dri usr/lib/i386-linux-gnu/dri; do
        [ ! -d "$upper/$dir" ] && continue
        rm -f "$upper/$dir/nvidia_drv_video.so" 2>/dev/null || true
        rm -rf "$upper/$dir/nvidia-vaapi-driver" 2>/dev/null || true
    done

    for dir in usr/lib64/gbm usr/lib/gbm usr/lib/x86_64-linux-gnu/gbm; do
        rm -f "$upper/$dir"/nvidia* 2>/dev/null || true
    done

    rm -rf "$upper/etc/X11/lib_nvidia" "$upper/etc/X11/lib64_nvidia" "$upper/etc/X11/lib32_nvidia" 2>/dev/null || true
    rm -rf "$upper/usr/lib/nvidia-current" 2>/dev/null || true
    rm -f "$upper/../nvidia_version" 2>/dev/null || true
}

# Find a file: try standard path, then broad search across /usr /etc /run /nix
nvidia_find_file() {
    local name="$1"
    local std_path="$2"
    if [ -n "$std_path" ] && [ -f "$std_path" ]; then
        echo "$std_path"
        return 0
    fi
    find /usr /etc /run /nix -name "$name" -type f -print -quit 2>/dev/null
}

nvidia_setup() {
    local version
    version=$(nvidia_get_version)

    if nvidia_is_cached; then
        [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: driver $version already cached, skipping" >&2
        return 0
    fi

    echo "NVIDIA: setting up driver $version..." >&2

    nvidia_clean_upper "$OVERLAY_MERGED"
    nvidia_detect_libdir

    [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: lib64=$NVIDIA_LIB64 lib32=$NVIDIA_LIB32" >&2

    local upper="$OVERLAY_MERGED"
    mkdir -p "$upper/$NVIDIA_LIB64" "$upper/$NVIDIA_LIB32"

    # --- Discover NVIDIA libraries via ldconfig (Conty-style) ---
    local ldconfig_bin=""
    for p in /sbin/ldconfig /usr/sbin/ldconfig /usr/bin/ldconfig; do
        [ -x "$p" ] && ldconfig_bin="$p" && break
    done
    if [ -z "$ldconfig_bin" ]; then
        echo "NVIDIA: ldconfig not found, skipping" >&2
        return 1
    fi

    local tmpdir="$WORKING_DIR/.nvidia_tmp"
    mkdir -p "$tmpdir"
    "$ldconfig_bin" -p 2>/dev/null > "$tmpdir/host_libs"

    # 1) All lines containing "nvidia" (case-insensitive) — catches libnvidia*, libGLX_nvidia, etc.
    grep -i "nvidia" "$tmpdir/host_libs" | sed 's/.* => //' > "$tmpdir/nvidia_libs" 2>/dev/null || true
    # 2) All libcuda libraries (not always named with "nvidia")
    grep -i "libcuda" "$tmpdir/host_libs" | sed 's/.* => //' >> "$tmpdir/nvidia_libs" 2>/dev/null || true
    # 3) All libnv* libraries that actually belong to NVIDIA (verified via strings)
    if command -v strings >/dev/null 2>&1; then
        while IFS= read -r path; do
            [ -f "$path" ] || continue
            if strings "$path" 2>/dev/null | grep -qi -m 1 "nvidia"; then
                echo "$path" >> "$tmpdir/nvidia_libs"
            fi
        done < <(grep "libnv" "$tmpdir/host_libs" | sed 's/.* => //' 2>/dev/null)
    else
        # Fallback: grab all libnv* without strings check
        grep "libnv" "$tmpdir/host_libs" | sed 's/.* => //' >> "$tmpdir/nvidia_libs" 2>/dev/null || true
    fi

    # Deduplicate
    sort -u "$tmpdir/nvidia_libs" > "$tmpdir/nvidia_libs_uniq" 2>/dev/null
    mv "$tmpdir/nvidia_libs_uniq" "$tmpdir/nvidia_libs"

    if [ ! -s "$tmpdir/nvidia_libs" ]; then
        echo "NVIDIA: no libraries found on host" >&2
        rm -rf "$tmpdir"
        return 1
    fi

    # --- Copy libraries ---
    local count=0 have_file_cmd=0
    command -v file >/dev/null 2>&1 && have_file_cmd=1

    while IFS= read -r path; do
        [ -f "$path" ] || continue

        local fname="${path##*/}"
        # Skip versioned libs (.so.X.Y.Z) from other driver versions;
        # soname links (.so, .so.1) are always copied
        case "$fname" in
            *.so.[0-9]*.[0-9]*)
                case "$fname" in *".$version") ;; *) continue ;; esac ;;
        esac

        # Detect 32-bit vs 64-bit
        local target_dir="$upper/$NVIDIA_LIB64"
        if [ "$have_file_cmd" = 1 ]; then
            if file "$(readlink -f "$path")" 2>/dev/null | grep -q "32-bit"; then
                target_dir="$upper/$NVIDIA_LIB32"
            fi
        else
            # Fallback: parse ldconfig -p architecture tag
            local ldline
            ldline=$(grep -F "$path" "$tmpdir/host_libs" | head -1)
            case "$ldline" in
                *x86-64*|*x86_64*|*ELF-64*) ;; # 64-bit, default
                *) target_dir="$upper/$NVIDIA_LIB32" ;;
            esac
        fi

        mkdir -p "$target_dir"
        if cp -fL "$path" "$target_dir/" 2>/dev/null; then
            count=$((count + 1))
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: lib $fname" >&2
        fi
    done < "$tmpdir/nvidia_libs"

    [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: copied $count libraries" >&2

    if [ "$count" -eq 0 ]; then
        echo "NVIDIA: failed to copy any libraries" >&2
        rm -rf "$tmpdir"
        return 1
    fi

    # --- Library directories (ALT Linux symlink targets) ---
    for nvidia_libdir in /etc/X11/lib_nvidia /etc/X11/lib64_nvidia /etc/X11/lib32_nvidia /usr/lib/nvidia-current; do
        if [ -d "$nvidia_libdir" ] || [ -L "$nvidia_libdir" ]; then
            local target_parent
            target_parent="$(dirname "$upper$nvidia_libdir")"
            mkdir -p "$target_parent"
            cp -aL "$nvidia_libdir" "$target_parent/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: dir $nvidia_libdir" >&2
        fi
    done

    # --- Binaries ---
    mkdir -p "$upper/usr/bin"
    local bin
    for bin in nvidia-smi nvidia-debugdump nvidia-persistenced nvidia-cuda-mps-control nvidia-cuda-mps-server; do
        local bin_path=""
        bin_path=$(command -v "$bin" 2>/dev/null) || true
        if [ -z "$bin_path" ]; then
            for p in /usr/bin /usr/sbin /usr/lib/nvidia; do
                [ -x "$p/$bin" ] && bin_path="$p/$bin" && break
            done
        fi
        [ -n "$bin_path" ] && cp -fL "$bin_path" "$upper/usr/bin/" 2>/dev/null || true
    done

    # --- Config files (Vulkan, EGL, Wine, profiles) ---
    # Search standard paths first, fall back to broad search (NixOS, Guix, non-FHS)
    # For each found file, also grab sibling *nvidia* files from the source directory

    nvidia_other_files="/usr/share/vulkan/icd.d/nvidia_icd.json \
        /usr/share/vulkan/implicit_layer.d/nvidia_layers.json \
        /usr/lib/nvidia/wine/nvngx.dll \
        /usr/lib/nvidia/wine/_nvngx.dll \
        /usr/share/egl/egl_external_platform.d/20_nvidia_xcb.json \
        /usr/share/nvidia/nvidia-application-profiles-${version}-rc"

    for f in $nvidia_other_files; do
        local filedir="${f%/*}"
        local filepath=""
        filepath=$(nvidia_find_file "${f##*/}" "$f") || true

        if [ -n "$filepath" ] && [ -f "$filepath" ]; then
            mkdir -p "$upper/$filedir"
            cp -fL "$filepath" "$upper/$filedir/" 2>/dev/null || true
            # Grab all nvidia* siblings from the source directory
            cp -fL "$(dirname "$filepath")"/*nvidia* "$upper/$filedir/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: cfg ${f##*/}" >&2
        fi
    done

    # --- EGL vendor: force 10_nvidia.json priority (wins over Mesa's 50_mesa.json) ---
    local egl_vendor_dir="$upper/usr/share/glvnd/egl_vendor.d"
    local egl_src=""
    egl_src=$(nvidia_find_file "" "/usr/share/glvnd/egl_vendor.d/10_nvidia.json") || true
    if [ -z "$egl_src" ] || [ ! -f "$egl_src" ]; then
        egl_src=$(find /usr /etc /run /nix -path "*/egl_vendor.d/*nvidia*" -type f -print -quit 2>/dev/null) || true
    fi
    if [ -n "$egl_src" ] && [ -f "$egl_src" ]; then
        mkdir -p "$egl_vendor_dir"
        cp -fL "$egl_src" "$egl_vendor_dir/10_nvidia.json" 2>/dev/null || true
        [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: EGL vendor -> 10_nvidia.json" >&2
    fi

    # --- EGL external platform (Wayland, XCB, etc.) fallback ---
    if ! ls "$upper/usr/share/egl/egl_external_platform.d/"*nvidia* >/dev/null 2>&1; then
        local egl_plat
        for egl_plat in $(find /usr /etc /run /nix -path "*/egl_external_platform.d/*nvidia*" -type f 2>/dev/null); do
            mkdir -p "$upper/usr/share/egl/egl_external_platform.d"
            cp -fL "$egl_plat" "$upper/usr/share/egl/egl_external_platform.d/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: EGL platform ${egl_plat##*/}" >&2
        done
    fi

    # --- Vulkan fallback (if standard copy missed it) ---
    if [ ! -f "$upper/usr/share/vulkan/icd.d/nvidia_icd.json" ]; then
        local vk_icd
        vk_icd=$(find /usr /etc /run /nix -name "nvidia_icd.json" -type f -print -quit 2>/dev/null) || true
        if [ -n "$vk_icd" ]; then
            mkdir -p "$upper/usr/share/vulkan/icd.d"
            cp -fL "$vk_icd" "$upper/usr/share/vulkan/icd.d/" 2>/dev/null || true
            cp -fL "$(dirname "$vk_icd")"/*nvidia* "$upper/usr/share/vulkan/icd.d/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: Vulkan ICD fallback $vk_icd" >&2
        fi
    fi
    if [ ! -f "$upper/usr/share/vulkan/implicit_layer.d/nvidia_layers.json" ]; then
        local vk_layers
        vk_layers=$(find /usr /etc /run /nix -name "nvidia_layers.json" -type f -print -quit 2>/dev/null) || true
        if [ -n "$vk_layers" ]; then
            mkdir -p "$upper/usr/share/vulkan/implicit_layer.d"
            cp -fL "$vk_layers" "$upper/usr/share/vulkan/implicit_layer.d/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: Vulkan layers fallback $vk_layers" >&2
        fi
    fi

    # --- Wayland server lib (dependency of libnvidia-egl-wayland) ---
    local wl_server
    wl_server=$(grep 'libwayland-server\.so\.' "$tmpdir/host_libs" | head -1 | sed 's/.* => //') || true
    if [ -n "$wl_server" ] && [ -f "$wl_server" ]; then
        cp -fL "$wl_server" "$upper/$NVIDIA_LIB64/" 2>/dev/null || true
        [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: wayland-server ${wl_server##*/}" >&2
    fi

    # --- Wine DLSS (non-standard paths fallback) ---
    if [ ! -f "$upper/usr/lib/nvidia/wine/nvngx.dll" ]; then
        local wine_nvngx
        wine_nvngx=$(find /usr /run /nix -name "nvngx.dll" -path "*/nvidia/wine/*" -type f -print -quit 2>/dev/null) || true
        if [ -n "$wine_nvngx" ]; then
            mkdir -p "$upper/usr/lib/nvidia/wine"
            cp -fL "$(dirname "$wine_nvngx")"/*nvngx* "$upper/usr/lib/nvidia/wine/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: Wine DLSS from $(dirname "$wine_nvngx")" >&2
        fi
    fi

    # --- DRI / VA-API ---
    local dri_dirs="/usr/lib/dri /usr/lib64/dri /usr/lib/x86_64-linux-gnu/dri /usr/lib32/dri /usr/lib/i386-linux-gnu/dri"
    for dri_dir in $dri_dirs; do
        [ ! -d "$dri_dir" ] && continue
        if [ -f "$dri_dir/nvidia_drv_video.so" ]; then
            mkdir -p "$upper${dri_dir}"
            cp -fL "$dri_dir/nvidia_drv_video.so" "$upper${dri_dir}/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: DRI $dri_dir" >&2
        fi
        if [ -d "$dri_dir/nvidia-vaapi-driver" ]; then
            mkdir -p "$upper${dri_dir}"
            cp -rfL "$dri_dir/nvidia-vaapi-driver" "$upper${dri_dir}/" 2>/dev/null || true
        fi
    done

    # Cross-distro: ensure DRI driver in container's lib directory
    local container_dri="$upper/$NVIDIA_LIB64/dri"
    if [ ! -f "$container_dri/nvidia_drv_video.so" ]; then
        for dri_dir in $dri_dirs; do
            if [ -f "$upper${dri_dir}/nvidia_drv_video.so" ]; then
                mkdir -p "$container_dri"
                cp -fL "$upper${dri_dir}/nvidia_drv_video.so" "$container_dri/" 2>/dev/null || true
                break
            fi
        done
    fi

    # --- GBM (Wayland compositors) ---
    local gbm_dirs="/usr/lib64/gbm /usr/lib/gbm /usr/lib/x86_64-linux-gnu/gbm"
    for gbm_dir in $gbm_dirs; do
        if ls "$gbm_dir"/nvidia* >/dev/null 2>&1; then
            mkdir -p "$upper${gbm_dir}"
            cp -fL "$gbm_dir"/nvidia* "$upper${gbm_dir}/" 2>/dev/null || true
            [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: GBM from $gbm_dir" >&2
        fi
    done
    local container_gbm="$upper/$NVIDIA_LIB64/gbm"
    if ! ls "$container_gbm"/nvidia* >/dev/null 2>&1; then
        for gbm_dir in $gbm_dirs; do
            if ls "$upper${gbm_dir}"/nvidia* >/dev/null 2>&1; then
                mkdir -p "$container_gbm"
                cp -fL "$upper${gbm_dir}"/nvidia* "$container_gbm/" 2>/dev/null || true
                break
            fi
        done
    fi

    # --- Mesa DRI from non-standard paths (ALT: X11/modules/dri/) ---
    if [ -d "$OVERLAY_MERGED/usr/lib64/X11/modules/dri" ]; then
        mkdir -p "$upper/usr/lib64/dri"
        for dri in "$OVERLAY_MERGED/usr/lib64/X11/modules/dri"/*_dri.so; do
            [ -f "$dri" ] || continue
            local dri_name="${dri##*/}"
            if [ ! -f "$OVERLAY_MERGED/usr/lib64/dri/$dri_name" ]; then
                cp -fL "$dri" "$upper/usr/lib64/dri/" 2>/dev/null || true
                [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: Mesa DRI $dri_name" >&2
            fi
        done
    fi

    # --- Rebuild ld.so.cache inside container ---
    [ -n "$CAPSULE_DEBUG" ] && echo "NVIDIA: rebuilding ld.so.cache" >&2
    run_util "$WORKING_DIR/utils/bwrap" \
        --bind "$OVERLAY_MERGED" / \
        --dev-bind /dev /dev \
        --proc /proc \
        -- ldconfig 2>/dev/null || true

    echo "$version" > "$OVERLAY_BASE/nvidia_version"
    echo "NVIDIA: driver $version ready" >&2

    rm -rf "$tmpdir"
}
{{- end -}}
